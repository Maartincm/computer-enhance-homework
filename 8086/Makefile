CPP="g++"

BUILD=$(PWD)/build

RELEASE ?= 0
PROFILE ?= 0

OPTIMIZATION_FLAG=-O0
DEBUG_FLAG=-ggdb3 -g
SWITCHES=

ifeq ($(RELEASE),1)
OPTIMIZATION_FLAG=-O3
DEBUG_FLAG=-g
endif

ifeq ($(PROFILE),1)
SWITCHES+= -D PROFILE
# DEBUG_FLAG+= -g -pg
endif

COMMON_CPP_FLAGS=-Wall $(DEBUG_FLAG) $(OPTIMIZATION_FLAG) -I/usr/local/include

LINK_FLAGS=

MAIN_CPP=decode_8086.cpp
EXTRA_CPP=

build:
	$(CPP) $(COMMON_CPP_FLAGS) $(SWITCHES) -o decode-8086 $(MAIN_CPP) $(EXTRA_CPP) $(LINK_FLAGS)

.PHONY: build
